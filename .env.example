# ============ Database ============
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-value
POSTGRES_DB=vpnstore

# ============ Authentication ============
JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ============ Admin bootstrap ============
# Created automatically on first API startup. Change password after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password-min-12-chars

# ============ App ============
WEB_URL=http://localhost
HTTP_PORT=80
NEXT_PUBLIC_API_URL=/api

# ============ Object storage (optional) ============
# Leave empty to use local disk uploads (persisted in Docker volume).
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ============ Telegram bot (optional) ============
# Notifies admin when a new card-to-card order is submitted.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
